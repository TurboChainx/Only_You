# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas — use your own cluster URI (never commit real credentials)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT Authentication — generate a long random string for production
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=30d

# OpenAI API — key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4.1-mini

# Admin default (used by seed script — change after first login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeImmediately123!

# Public server URL (for image paths / links)
SERVER_URL=https://your-api-domain.com

# Optional: Firebase Admin JSON as single line (alternative to firebase-admin-key.json file)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
